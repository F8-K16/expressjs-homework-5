<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Reset Your Password</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f8;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 500px;
        margin: 40px auto;
        background: #ffffff;
        border-radius: 8px;
        padding: 24px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
      }
      .title {
        font-size: 22px;
        font-weight: bold;
        color: #333;
        margin-bottom: 16px;
      }
      .text {
        font-size: 14px;
        color: #555;
        margin-bottom: 24px;
      }
      .code {
        font-size: 28px;
        font-weight: bold;
        color: #f44336;
        letter-spacing: 4px;
        margin: 16px 0;
      }
      .footer {
        font-size: 12px;
        color: #999;
        margin-top: 24px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="title">Reset Your Password 🔒</div>

      <div class="text">
        We received a request to reset your password. Use the code below to
        continue.
      </div>

      <div class="code"><%= code %></div>

      <div class="text">
        This code will expire in <strong>15 minutes</strong>.
      </div>

      <div class="text">
        If you did not request a password reset, please ignore this email or
        secure your account.
      </div>

      <div class="footer">
        For your security, do not share this code with anyone.
      </div>
    </div>
  </body>
</html>
